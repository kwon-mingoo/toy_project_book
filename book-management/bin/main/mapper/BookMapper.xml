<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    BookMapper XML
    namespace: 매핑할 Mapper 인터페이스의 전체 경로
    MyBatis는 이 namespace를 보고 BookMapper 인터페이스의 메서드와 SQL을 연결
-->
<mapper namespace="com.example.bookmanagement.mapper.BookMapper">

    <!--
        resultMap: SQL 결과 컬럼과 Java 객체 필드를 명시적으로 매핑
        application.yml의 map-underscore-to-camel-case: true 설정으로 자동 변환되지만
        JOIN으로 가져오는 CATEGORY_NAME처럼 도메인 필드명과 다를 때는 명시 필요
    -->
    <resultMap id="bookResultMap" type="Book">
        <id     property="bookId"       column="BOOK_ID"/>
        <result property="title"        column="TITLE"/>
        <result property="author"       column="AUTHOR"/>
        <result property="publisher"    column="PUBLISHER"/>
        <result property="price"        column="PRICE"/>
        <result property="stock"        column="STOCK"/>
        <result property="categoryId"   column="CATEGORY_ID"/>
        <result property="categoryName" column="CATEGORY_NAME"/>
        <result property="createdAt"    column="CREATED_AT"/>
        <result property="updatedAt"    column="UPDATED_AT"/>
    </resultMap>

    <!-- 재사용 가능한 SELECT 컬럼 목록 -->
    <sql id="bookColumns">
        b.BOOK_ID, b.TITLE, b.AUTHOR, b.PUBLISHER, b.PRICE, b.STOCK,
        b.CATEGORY_ID, c.CATEGORY_NAME, b.CREATED_AT, b.UPDATED_AT
    </sql>

    <!--
        동적 SQL: <where> + <if> 조합
        <where>: 조건이 하나도 없으면 WHERE 절 자체를 생략, 있으면 첫 AND를 자동으로 제거
        <if test="...">: OGNL 표현식으로 조건 분기
    -->
    <sql id="searchCondition">
        <where>
            <if test="title != null and title != ''">
                AND UPPER(b.TITLE) LIKE '%' || UPPER(#{title}) || '%'
            </if>
            <if test="author != null and author != ''">
                AND UPPER(b.AUTHOR) LIKE '%' || UPPER(#{author}) || '%'
            </if>
            <if test="categoryId != null">
                AND b.CATEGORY_ID = #{categoryId}
            </if>
        </where>
    </sql>

    <!--
        도서 목록 조회 (페이지네이션)
        Oracle 12c 이상: OFFSET ~ ROWS FETCH NEXT ~ ROWS ONLY 문법 사용
        #{offset}: BookSearchDto.getOffset() 호출 → (page-1) * size
        #{size}:   BookSearchDto.getSize()   호출
    -->
    <select id="findAll" parameterType="BookSearchDto" resultMap="bookResultMap">
        SELECT <include refid="bookColumns"/>
        FROM book b
        LEFT JOIN category c ON b.CATEGORY_ID = c.CATEGORY_ID
        <include refid="searchCondition"/>
        ORDER BY b.BOOK_ID DESC
        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    </select>

    <!-- 전체 건수 조회 (페이지 수 계산용) -->
    <select id="countAll" parameterType="BookSearchDto" resultType="long">
        SELECT COUNT(*)
        FROM book b
        <include refid="searchCondition"/>
    </select>

    <!-- 도서 단건 조회 -->
    <select id="findById" parameterType="long" resultMap="bookResultMap">
        SELECT <include refid="bookColumns"/>
        FROM book b
        LEFT JOIN category c ON b.CATEGORY_ID = c.CATEGORY_ID
        WHERE b.BOOK_ID = #{bookId}
    </select>

    <!--
        도서 등록
        <selectKey>: INSERT 전에 Oracle 시퀀스에서 다음 값을 가져와 book.bookId에 세팅
        keyProperty: 결과를 저장할 파라미터 객체의 필드명
        order="BEFORE": INSERT 실행 전에 SELECT NEXTVAL 실행
    -->
    <insert id="insert" parameterType="Book">
        <selectKey keyProperty="bookId" resultType="long" order="BEFORE">
            SELECT seq_book.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO book (BOOK_ID, TITLE, AUTHOR, PUBLISHER, PRICE, STOCK, CATEGORY_ID, CREATED_AT, UPDATED_AT)
        VALUES (#{bookId}, #{title}, #{author}, #{publisher}, #{price}, #{stock}, #{categoryId}, SYSDATE, SYSDATE)
    </insert>

    <!-- 도서 수정 -->
    <update id="update" parameterType="Book">
        UPDATE book
        SET TITLE       = #{title},
            AUTHOR      = #{author},
            PUBLISHER   = #{publisher},
            PRICE       = #{price},
            STOCK       = #{stock},
            CATEGORY_ID = #{categoryId},
            UPDATED_AT  = SYSDATE
        WHERE BOOK_ID = #{bookId}
    </update>

    <!-- 도서 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM book WHERE BOOK_ID = #{bookId}
    </delete>

</mapper>
